PORT=4000
APP_NAME=SHALOM
FRONTEND_URL=http://localhost:5173

# ── Database (AWS RDS PostgreSQL) ──
DATABASE_URL=postgresql://user:password@your-rds-endpoint.rds.amazonaws.com:5432/shalom
DB_SSL=true
# Path to the RDS CA bundle inside the container (downloaded by Dockerfile).
# Set to the same path used in the Dockerfile RUN step.
# Leave blank to disable certificate verification (not recommended in production).
RDS_CA_PATH=/etc/ssl/certs/rds-ca-bundle.pem

# ── Auth ──
JWT_SECRET=REPLACE_ME_USE_32_RANDOM_HEX_BYTES

# ── Super Admin ──
SUPER_ADMIN_EMAILS=admin@example.com
PRIMARY_SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PHONES=+919999999999
PRIMARY_SUPER_ADMIN_PHONE=+919999999999

# ── Payments (Razorpay Routes — platform-level credentials only) ──
# These are the PLATFORM account credentials, not per-church keys.
# Per-church routing is handled via Razorpay Routes linked accounts.
PAYMENTS_ENABLED=false
RAZORPAY_KEY_ID=REPLACE_ME_PLATFORM_KEY_ID
# Razorpay API secret — do NOT commit real value
RAZORPAY_KEY_SECRET=REPLACE_ME_PLATFORM_KEY_SECRET
# Webhook secret from Razorpay Dashboard → Settings → Webhooks → Secret
# This is DIFFERENT from the API key secret above.
RAZORPAY_WEBHOOK_SECRET=REPLACE_ME_GET_FROM_RAZORPAY_DASHBOARD_WEBHOOKS

# ── Manual payment date floor ──
# Earliest allowed date for admin manual payment recording.
MIN_PAYMENT_DATE=2025-01-01

# ── AWS (used for S3 uploads and SES email) ──
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=REPLACE_ME
AWS_SECRET_ACCESS_KEY=REPLACE_ME

# ── SMTP (optional — used if SES is not configured) ──
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ── Twilio (phone OTP + SMS) ──
TWILIO_ACCOUNT_SID=REPLACE_ME
TWILIO_AUTH_TOKEN=REPLACE_ME
TWILIO_VERIFY_SERVICE_SID=REPLACE_ME
TWILIO_MESSAGING_SERVICE_SID=

# ── Push Notifications (VAPID) ──
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# ── OTP Settings ──
OTP_EXPIRY_SECONDS=600

# ── Error tracking (Sentry) ──
SENTRY_DSN=
